# Docker Hub (obrigatório para publicar e fazer deploy no servidor)
DOCKERHUB_USER=seu-usuario-dockerhub
IMAGE_TAG=latest

# Portas (local: 8080 evita conflito com IIS/outros serviços na 80)
WEB_PORT=8080
API_PORT=3000

# Oracle dedicado à pré-validação (padrão do docker-compose)
ORACLE_USER=validator
ORACLE_PASSWORD=ValidatorPass1
ORACLE_ADMIN_PASSWORD=ValidatorAdmin1
ORACLE_CONNECT_STRING=oracle:1521/XEPDB1

# Para usar um Oracle externo em vez do container, sobrescreva:
# ORACLE_CONNECT_STRING=ip-externo:1521/servico
